{
  "name": "nib",
  "version": "0.2.0",
  "description": "TypeScript library and CLI for driving AxiDraw plotters via native EBB protocol",
  "license": "MIT",
  "author": "Jeff Heuer",
  "homepage": "https://github.com/jheuer/nib",
  "repository": {
    "type": "git",
    "url": "https://github.com/jheuer/nib.git"
  },
  "keywords": ["axidraw", "ebb", "plotter", "generative-art", "svg", "drawing"],
  "type": "module",
  "bin": {
    "nib": "./dist/nib-cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build:cli": "bun build --compile src/cli/index.ts --outfile dist/nib",
    "build:cli:npm": "bun build src/cli/index.ts --outfile dist/nib-cli.js --target node && node -e \"const fs=require('fs');const f='dist/nib-cli.js';let c=fs.readFileSync(f,'utf8');if(c.startsWith('#!'))c=c.replace(/^#![^\\n]*\\n?/,'');fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)\" && chmod +x dist/nib-cli.js",
    "build:lib": "bun build src/index.ts --outdir dist --target node",
    "build:browser": "bun build src/browser.ts --outdir dist --target browser",
    "build": "bun run build:cli && bun run build:cli:npm && bun run build:lib && bun run build:browser",
    "prepublishOnly": "bun run build:lib && bun run build:browser && bun run build:cli:npm",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:examples": "bunx tsc --noEmit -p tsconfig.examples.json",
    "example:canvas": "bun examples/browser/canvas/serve.ts",
    "example:p5":     "bun examples/browser/p5/serve.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.0",
    "citty": "^0.1.6",
    "ora": "^9.3.0",
    "smol-toml": "^1.3.1",
    "svg-pathdata": "^6.0.3",
    "svgson": "^5.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5"
  }
}
