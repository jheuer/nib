{
  "name": "nib",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "nib": "./dist/nib"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build:cli": "bun build --compile src/cli/index.ts --outfile dist/nib",
    "build:lib": "bun build src/index.ts --outdir dist --target bun",
    "build:browser": "bun build src/browser.ts --outdir dist --target browser",
    "build": "bun run build:cli && bun run build:lib && bun run build:browser",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "example:canvas": "bun examples/browser/canvas/serve.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.0",
    "citty": "^0.1.6",
    "ora": "^9.3.0",
    "smol-toml": "^1.3.1",
    "svg-pathdata": "^6.0.3",
    "svgson": "^5.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5"
  }
}
